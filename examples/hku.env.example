# HKU VPN configuration
# Copy this file to ~/.vpn/hku.env and fill in your details.

# Your HKU email (uid@connect.hku.hk for students, uid@hku.hk for staff)
HKU_USER=youruid@connect.hku.hk

# VPN endpoint: 'cn' for mainland China (faster from CN), 'hk' for Hong Kong
# You can override this per-invocation with: hkuvpn cn / hkuvpn hk
HKU_ENDPOINT=hk

# Optional: override host-side proxy ports if 1080/1088 are already in use
# (e.g. you have Surge, Clash, or another local proxy on these ports).
# The container always exposes ports 1080/1088 internally; these settings
# only change what your Mac sees.
# HKU_SOCKS_PORT=11080
# HKU_HTTP_PORT=11088

# Advanced: pin vpn2fa.hku.hk to one real gateway for the whole session.
# This can prevent an authenticated reconnect from landing on another backend.
# Do not use a fake-IP address (for example, Surge Enhanced Mode's 198.18.0.0/15).
# HKU_RESOLVE=vpn2fa.hku.hk:203.0.113.10
